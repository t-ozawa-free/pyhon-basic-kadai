     "text": [
      "私の名前は山田太郎です。年齢は25歳です。\n",
      "私の名前は侍太郎です。年齢は42歳です。\n"
     ]
    }
   ],
   "source": [
    "class Human:\n",
    "    def __init__(self, name, age):\n",
    "        self.name = name\n",
    "        self.age = age\n",
    "    def printinfo(self):\n",
    "        print(f\"私の名前は{self.name}です。年齢は{self.age}歳です。\")\n",
    "\n",
    "human = Human(\"山田太郎\", 25)\n",
    "human.printinfo()\n",
    "\n",
    "human.name = \"侍太郎\"\n",
    "human.age = 42\n",
    "human.printinfo()"
   ]
  },
