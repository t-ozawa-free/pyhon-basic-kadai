    "\n",
    "def cal_sale(price:int, tax:int):\n",
    "    \"\"\"\n",
    "    税込価格を計算する関数\n",
    "    price: 価格\n",
    "    tax: 税率\n",
    "    return: 税込価格\n",
    "    \"\"\"\n",
    "    try:\n",
    "        return price * (1 + tax / 100)\n",
    "    except (ValueError, TypeError):\n",
    "        return \"数値を入力してください\"\n",
    "\n",
    "print(cal_sale(110, 10))\n",
    "\n",
    "\n"
   ]
