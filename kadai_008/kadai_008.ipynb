   "source": [
    "import random\n",
    "\n",
    "var = random.randint(1, 1000)\n",
    "\n",
    "fizz = 3\n",
    "buzz = 5\n",
    "\n",
    "if var % (fizz * buzz) == 0:\n",
    "    print(f\"{var} : FizzBuzz\")\n",
    "elif var % fizz == 0:\n",
    "    print(f\"{var} : Fizz\")\n",
    "elif var % buzz == 0:\n",
    "    print(f\"{var} : Buzz\")\n",
    "else:\n",
    "    print(f\"{var}\")\n"
   ]
